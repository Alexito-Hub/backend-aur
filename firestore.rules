rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // =============================================
    // USERS — Main user profile collection
    // =============================================
    match /users/{userId} {
      // Users can only read their own document
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Initial creation: only with safe default values
      allow create: if isAuthenticated()
                    && request.auth.uid == userId
                    && request.resource.data.requestsCount == 0
                    && request.resource.data.totalLimit == 10
                    && request.resource.data.plan == 'free'
                    && request.resource.data.email == request.auth.token.email;

      // Client can only update cosmetic fields — plan/limits are ONLY writable by Admin SDK
      allow update: if isAuthenticated()
                    && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['displayName', 'photoURL', 'lastActive']); 
      
      allow delete: if false;
    }
    
    // =============================================
    // UNAUTH_USAGE — Anonymous request tracking
    // Completely blocked from clients
    // =============================================
    match /unauth_usage/{hash} {
      allow read, write: if false;
    }

    // =============================================
    // PAYMENTS — Payment receipts
    // Read-only by the owning user, write only by Admin SDK
    // =============================================
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // =============================================
    // HISTORY — Download history (cloud-synced)
    // Users can only read/write their own history items.
    // Client can delete own entries, but not modify userId.
    // =============================================
    match /history/{historyId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Only backend (Admin SDK) can create history entries
      allow create: if false;
      
      // Client cannot modify any history entry
      allow update: if false;
      
      // Client can delete only their own entries
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
